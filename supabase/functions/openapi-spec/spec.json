      "get": {
        "tags": [
          "Provider Portal · EMR"
        ],
        "summary": "Fetch the EMR snapshot for a consented patient.",
        "description": "Returns records, medications, appointments, and claims permitted by the consent's `scopes`. Server enforces consent scope + expiry; revoked consents return 403.",
        "parameters": [
          {
            "in": "query",
            "name": "patient_id",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          },
          {
            "in": "query",
            "name": "consent_id",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Aggregated EMR bundle",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProviderEmrBundle"
                }
              }
            }
          },
          "403": {
